{
  "name": "file-viewer",
  "version": "0.1.0",
  "description": "Standalone CLI tool that serves a folder as a web-based document viewer with markdown rendering, syntax highlighting, math, and diagrams.",
  "type": "module",
  "license": "MIT",
  "author": "Moriz Mensi-Klarbach",
  "homepage": "https://github.com/OWNER/file-viewer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OWNER/file-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/OWNER/file-viewer/issues"
  },
  "keywords": [
    "markdown",
    "viewer",
    "cli",
    "documentation",
    "file-browser",
    "angular",
    "express"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "file-serve": "./dist/server/bin/file-viewer.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build:frontend": "cd frontend && npx ng build --configuration production",
    "build:server": "tsc -p tsconfig.json",
    "build": "npm run build:frontend && npm run build:server",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "express": "^5.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "~5.7.2"
  }
}
